<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Predict — LiquidGlass palette -->
    <Color x:Key="AccentPrimary">#7C3AED</Color>
    <Color x:Key="AccentLight">#C084FC</Color>
    <Color x:Key="AccentBlue">#60A5FA</Color>
    <Color x:Key="AccentPink">#F472B6</Color>
    <Color x:Key="AccentGreen">#34D399</Color>

    <Color x:Key="PageBackground">#08081C</Color>
    <Color x:Key="CardBackground">#0D0D2B</Color>
    <Color x:Key="CardBorder">#2D2060</Color>

    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#A0AACC</Color>
    <Color x:Key="TextMuted">#505870</Color>

    <Color x:Key="InputBackground">#06061A</Color>
    <Color x:Key="InputBorder">#3D2A6A</Color>

    <Color x:Key="ResultCardBg">#150D3A</Color>
    <Color x:Key="ResultCardBorder">#7C3AED</Color>
    <Color x:Key="ResultCardSecBg">#0D1A30</Color>
    <Color x:Key="ResultCardSecBorder">#60A5FA</Color>

    <Color x:Key="ErrorColor">#F472B6</Color>
    <Color x:Key="DividerColor">#1A1A3A</Color>

    <!-- Required by MAUI internals -->
    <Color x:Key="Primary">#7C3AED</Color>
    <Color x:Key="PrimaryDark">#C084FC</Color>
    <Color x:Key="PrimaryDarkText">#08081C</Color>
    <Color x:Key="Secondary">#60A5FA</Color>
    <Color x:Key="SecondaryDarkText">#A0AACC</Color>
    <Color x:Key="Tertiary">#F472B6</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource AccentBlue}"/>

</ResourceDictionary>
