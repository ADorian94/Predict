<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:vm="clr-namespace:Predict.ViewModels"
             x:Class="Predict.SettingsPage"
             BackgroundColor="{DynamicResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="20,4,20,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,4,0,20">
            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeThickness="1"
                    Background="{DynamicResource CardAltBackgroundBrush}"
                    Stroke="{DynamicResource CardBorderBrush}">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="&#xE5C4;" FontFamily="MaterialIcons"
                       FontSize="22" TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0,0,0" VerticalOptions="Center">
                <Label Text="SETTINGS"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{DynamicResource AccentLight}" CharacterSpacing="2"/>
                <Label Text="PREFERENCES"
                       FontSize="14" TextColor="{DynamicResource LabelSubtitle}" CharacterSpacing="4"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20">

                <!-- Unit of weight -->
                <Label Text="UNIT OF WEIGHT"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"
                       Margin="4,0,0,0"/>
                <Border Padding="18,16" StrokeThickness="1.5"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Stroke="{DynamicResource CardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Padding="0,16" StrokeThickness="1.5"
                                Background="{Binding KgBackground}"
                                Stroke="{Binding KgBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectKgCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="kg" FontSize="16" FontAttributes="Bold"
                                   TextColor="{Binding KgTextColor}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1" Padding="0,16" StrokeThickness="1.5"
                                Background="{Binding LbsBackground}"
                                Stroke="{Binding LbsBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectLbsCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="lbs" FontSize="16" FontAttributes="Bold"
                                   TextColor="{Binding LbsTextColor}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Best estimation rounding -->
                <Label Text="BEST ESTIMATION"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"
                       Margin="4,0,0,0"/>
                <Border Padding="18,16" StrokeThickness="1.5"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Stroke="{DynamicResource CardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Padding="0,16" StrokeThickness="1.5"
                                Background="{Binding RoundedBackground}"
                                Stroke="{Binding RoundedBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectRoundedCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="ROUNDED" FontSize="13" FontAttributes="Bold"
                                   TextColor="{Binding RoundedTextColor}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1" Padding="0,16" StrokeThickness="1.5"
                                Background="{Binding RawBackground}"
                                Stroke="{Binding RawBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectRawCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="RAW" FontSize="13" FontAttributes="Bold"
                                   TextColor="{Binding RawTextColor}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Appearance / Theme -->
                <Label Text="APPEARANCE"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"
                       Margin="4,0,0,0"/>
                <Border Padding="18,16" StrokeThickness="1.5"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Stroke="{DynamicResource CardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- Dark -->
                        <Border Grid.Column="0" Padding="0,14" StrokeThickness="1.5"
                                Background="{Binding DarkBackground}"
                                Stroke="{Binding DarkBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDarkCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#xE51C;" FontFamily="MaterialIcons"
                                       FontSize="18" TextColor="{Binding DarkTextColor}"
                                       HorizontalOptions="Center"/>
                                <Label Text="DARK" FontSize="11" FontAttributes="Bold"
                                       TextColor="{Binding DarkTextColor}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Light -->
                        <Border Grid.Column="1" Padding="0,14" StrokeThickness="1.5"
                                Background="{Binding LightBackground}"
                                Stroke="{Binding LightBorder}">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectLightCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#xE518;" FontFamily="MaterialIcons"
                                       FontSize="18" TextColor="{Binding LightTextColor}"
                                       HorizontalOptions="Center"/>
                                <Label Text="LIGHT" FontSize="11" FontAttributes="Bold"
                                       TextColor="{Binding LightTextColor}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
