<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:vm="clr-namespace:Predict.ViewModels"
             xmlns:conv="clr-namespace:Predict.Converters"
             x:Class="Predict.MainPage"
             BackgroundColor="{DynamicResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,8,20,8" Spacing="12">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="PREDICT"
                               FontSize="42" FontAttributes="Bold"
                               TextColor="{DynamicResource AccentLight}" CharacterSpacing="2"/>
                        <Label Text="1RM ESTIMATOR"
                               FontSize="14" TextColor="{DynamicResource LabelSubtitle}" CharacterSpacing="4"/>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="20" VerticalOptions="Center">
                        <Label Text="&#xE889;" FontFamily="MaterialIcons"
                               FontSize="28" TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowHistoryCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="&#xE8B8;" FontFamily="MaterialIcons"
                               FontSize="28" TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowSettingsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Weight card -->
                <Border x:Name="WeightCard" Padding="18,16" StrokeThickness="1.5"
                        Opacity="0" TranslationY="40"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Stroke="{DynamicResource CardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding WeightLabel}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"/>
                        <Entry Text="{Binding WeightText}"
                               Placeholder="120"
                               Keyboard="Numeric"
                               BackgroundColor="Transparent"
                               TextColor="{DynamicResource TextPrimary}"
                               PlaceholderColor="{DynamicResource PlaceholderText}"
                               FontSize="28" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               HeightRequest="56"/>
                        <Label Text="{Binding WeightError}"
                               FontSize="13" TextColor="{DynamicResource ErrorColor}"
                               IsVisible="{Binding WeightError, Converter={StaticResource StringNotEmptyConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Reps card -->
                <Border x:Name="RepsCard" Padding="18,16" StrokeThickness="1.5"
                        Opacity="0" TranslationY="40"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Stroke="{DynamicResource CardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="REPS"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"/>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,4,0,4">
                            <Border Grid.Column="0" WidthRequest="52" HeightRequest="52" StrokeThickness="1.5"
                                    Background="{DynamicResource CardAltBackgroundBrush}"
                                    Stroke="{DynamicResource CardBorderBrush}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DecrementRepsCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="&#xE15B;"
                                       FontFamily="MaterialIcons"
                                       FontSize="24" TextColor="{DynamicResource AccentLight}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding RepsText}"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="2" WidthRequest="52" HeightRequest="52" StrokeThickness="1.5"
                                    Background="{DynamicResource CardAltBackgroundBrush}"
                                    Stroke="{DynamicResource CardBorderBrush}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding IncrementRepsCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="&#xE145;"
                                       FontFamily="MaterialIcons"
                                       FontSize="24" TextColor="{DynamicResource AccentLight}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        <Label Text="{Binding RepsError}"
                               FontSize="13" TextColor="{DynamicResource ErrorColor}"
                               IsVisible="{Binding RepsError, Converter={StaticResource StringNotEmptyConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- RPE card -->
                <Border x:Name="RpeCard" Padding="18,16" StrokeThickness="1.5"
                        Opacity="0" TranslationY="40"
                        Background="{DynamicResource AccentCardBackgroundBrush}"
                        Stroke="{DynamicResource AccentCardBorderBrush}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="RPE"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource LabelMuted}" CharacterSpacing="2"/>
                            <Label Grid.Column="1"
                                   Text="{Binding RpeDisplay}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{Binding RpeColor}"/>
                        </Grid>
                        <Slider Minimum="6" Maximum="10"
                                Value="{Binding Rpe}"
                                MinimumTrackColor="{Binding RpeColor}"
                                ThumbColor="{Binding RpeColor}"
                                MaximumTrackColor="{DynamicResource SliderTrack}"/>
                        <Grid ColumnDefinitions="*,*,*,*,*">
                            <Label Grid.Column="0" Text="6" FontSize="11" TextColor="{DynamicResource LabelMuted}"/>
                            <Label Grid.Column="1" Text="7" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="8" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3" Text="9" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="4" Text="10" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="End"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{DynamicResource SliderTrack}"/>
                        <Grid ColumnDefinitions="*,*,*">
                            <Label Grid.Column="0" Text="6 - easy" FontSize="11" TextColor="{DynamicResource LabelMuted}"/>
                            <Label Grid.Column="1" Text="8 - hard" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="10 - max" FontSize="11" TextColor="{DynamicResource LabelMuted}" HorizontalTextAlignment="End"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ESTIMATE button -->
        <Border Grid.Row="1" StrokeThickness="1.5" HeightRequest="56" Margin="20,12,20,32"
                Background="{DynamicResource EstimateButtonBrush}"
                Stroke="{DynamicResource EstimateButtonStroke}">
            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16"/></Border.StrokeShape>
            <Button x:Name="CalcButton"
                    Text="ESTIMATE"
                    Command="{Binding CalculateCommand}"
                    Clicked="CalcButton_Clicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="16" FontAttributes="Bold"
                    CharacterSpacing="2"/>
        </Border>

    </Grid>

</ContentPage>
